# SentimentTools Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_SECRET_KEY=ubah-ini-ke-string-acak
DATABASE_URL=sqlite+aiosqlite:///./data/sentiment.db
CRAWLER_MAX_CONCURRENCY=10
CRAWLER_REQUEST_TIMEOUT=30
CRAWLER_MAX_DEPTH=2
CRAWLER_DELAY_SECONDS=0.5
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_USE_PLAYWRIGHT=false
NLP_DEVICE=cpu
NLP_MODEL_PATH=./models/indobert-sentiment
NLP_CONFIDENCE_THRESHOLD=0.75
NLP_BATCH_SIZE=8
NLP_MAX_TEXT_LENGTH=512
EXPORT_DIR=./data/exports
LOG_LEVEL=INFO
LOG_FILE=./data/logs/app.log